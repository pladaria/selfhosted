{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ComicMeta",
  "description": "Comic metadata schema for strict OpenAI structured outputs.",
  "type": "object",
  "required": [
    "title",
    "alternateTitles",
    "volumeCount",
    "series",
    "summary",
    "notes",
    "releaseDate",
    "artists",
    "genre",
    "tags",
    "rating",
    "publishingTradition",
    "demography"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "alternateTitles": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["locale", "title"],
            "properties": {
              "locale": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "volumeCount": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "series": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "releaseDate": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Release date in yyyy-mm-dd format."
        },
        {
          "type": "null"
        }
      ]
    },
    "artists": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "aka", "role"],
            "properties": {
              "name": {
                "type": "string"
              },
              "aka": {
                "anyOf": [
                  {
                    "type": "array",
                    "description": "Alternative names, pen names, romanizations, or aliases used by the author.",
                    "items": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "role": {
                "type": "string",
                "enum": [
                  "writer",
                  "penciller",
                  "inker",
                  "colorist",
                  "letterer",
                  "coverArtist",
                  "author"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "genre": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "tags": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "rating": {
      "anyOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Rating value between 0 and 10."
        },
        {
          "type": "null"
        }
      ]
    },
    "publishingTradition": {
      "anyOf": [
        {
          "type": "string",
          "description": "Publishing tradition or comics culture, e.g. manga, manhua, manhwa, franco-belgian, spanish, american, etc."
        },
        {
          "type": "null"
        }
      ]
    },
    "demography": {
      "anyOf": [
        {
          "type": "string",
          "description": "Target demographic. Values shojo, seinen, shonen, kodomo, and josei apply to manga only.",
          "enum": [
            "shojo",
            "seinen",
            "shonen",
            "kodomo",
            "josei",
            "children",
            "young-adult",
            "adult",
            "adult-erotic"
          ]
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
